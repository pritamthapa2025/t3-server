{
  "name": "t3-server",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc && node scripts/copy-templates.js",
    "build:skip-lint": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc && node scripts/copy-templates.js",
    "dev": "nodemon",
    "start": "node dist/server.js",
    "start:dev": "tsx --env-file=.env src/server.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts,.js --max-warnings 0",
    "lint:warnings-ok": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "seed": "tsx src/drizzle/seed/index.ts",
    "seed:features": "tsx src/drizzle/seed/featurePermissions.seed.ts",
    "seed:reset": "tsx src/drizzle/seed/resetAndReseed.ts",
    "seed:notification-rules": "tsx src/drizzle/seed/notificationRules.seed.ts",
    "seed:reset-notifications": "tsx src/drizzle/seed/resetNotifications.ts",
    "seed:field-crew": "tsx src/drizzle/seed/fieldCrew.seed.ts",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:verify": "tsx scripts/verify-migration.ts",
    "db:audit-timestamptz": "tsx scripts/audit-timestamptz-columns.ts",
    "db:check-columns": "echo 'Column analysis complete - see previous comprehensive analysis'",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:erd": "tsx scripts/generate-erd.ts",
    "migrate:enhanced": "tsx scripts/migrate.ts",
    "migrate:rollback": "tsx scripts/migrate.ts rollback",
    "migrate:interactive": "node scripts/run-migration.js",
    "health-check": "tsx scripts/health-check.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.15.2",
      "basic-ftp": ">=5.3.1",
      "fast-xml-parser": ">=5.7.0",
      "socket.io-parser": ">=4.2.6",
      "path-to-regexp": ">=8.4.0",
      "ws": ">=8.20.1",
      "follow-redirects": ">=1.16.0",
      "flatted": ">=3.4.2",
      "minimatch": "^10.2.5",
      "brace-expansion@<2": ">=1.1.13",
      "brace-expansion@>=2": ">=2.0.3",
      "picomatch": "^4.0.4",
      "esbuild@0.18.20": "0.25.12",
      "uuid@9.0.1": "11.1.1",
      "ajv": "6.14.0",
      "ip-address": ">=10.1.1",
      "qs": ">=6.15.2"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@getbrevo/brevo": "^4.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.6",
    "@types/puppeteer": "^5.4.7",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "database-error": "^2.0.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "googleapis": "^148.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "otplib": "^12.0.1",
    "pg": "^8.16.3",
    "pg-error-codes": "^1.1.0",
    "postgres": "^3.4.8",
    "puppeteer": "^24.35.0",
    "sanitize-html": "^2.17.4",
    "socket.io": "^4.8.1",
    "twilio": "^5.12.1",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "nodemon": "^3.1.11",
    "snyk": "^1.1305.0",
    "snyk-to-html": "^3.7.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6"
  }
}
